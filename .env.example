# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_WS_URL=ws://localhost:4000

# Database
DATABASE_URL=postgresql://salescoach:salescoach@localhost:5432/salescoach?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production

# Google AI (Gemini + Live API)
GOOGLE_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Realtime audio
LIVE_AUDIO_SAMPLE_RATE=16000
LIVE_AUDIO_CHANNELS=1
LIVE_TRANSCRIPTION_LANGUAGE=es-ES

# Optional fallback transcription
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# Optional telephony
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional CRM
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=

# Security / privacy
STORE_AUDIO=false
STORE_TRANSCRIPTS=true
DATA_RETENTION_DAYS=90
